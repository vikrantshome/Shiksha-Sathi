# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!**/.env.example

# Prevent .env in backend resources from ever being committed
backend/api/src/main/resources/.env
backend/api/src/main/resources/.env.*
scripts/**/.env
scripts/**/.env.*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Gradle
.gradle/
**/build/
!**/gradle/wrapper/gradle-wrapper.jar

# Compiled class files
*.class
*.jar
*.war
*.ear

# IntelliJ
.idea/
*.iws
*.iml
*.ipr

# Eclipse
.settings/
.project
.classpath
.factorypath

# VS Code
.vscode/

# Logs
*.log

# accidental commits
doc/temporary stuck chat/

# Local database files
data/
# Ignore NCERT content artifacts by default but allow selected policy files
doc/NCERT/**
!doc/NCERT/
!doc/NCERT/coverage-ledger.json
!doc/NCERT/derived-question-workflow.md
!doc/NCERT/publish-workflow.md
!doc/NCERT/derived-reference-allowlist.md
.env*.local

# Exemplar PDFs (large binaries, download via scripts)
doc/Exemplar/*.pdf

# AI Assistant Settings
.qwen/
.gemini/
.worktrees/
.kilo/
.opencode/
.ruff_cache/
.pytest_cache/

# Build and Output
bin/
**/bin/
.gradle/
**/build/
.gemini/
scratch/

# Knowledge graph (generated)
graphify-out/
backend/graphify-out/
google/
test-results/
opencode.json

# Lock files - using yarn
package-lock.json

# Screenshots and local images
*.png
*.jpg
*.jpeg
*.gif
*.svg
!public/**/*.svg
!public/**/*.png
!public/**/*.jpg
!public/**/*.jpeg
!public/**/*.gif
!src/**/*.svg
