{
  "name": "shiksha-sathi-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "kill-port --port 4000 --port 8080",
    "predev:frontend": "kill-port --port 4000",
    "predev:backend": "kill-port --port 8080",
    "dev:frontend": "APP_ROOT=\"$(dirname \"$npm_package_json\")\" && cd \"$APP_ROOT\" && next dev --webpack --port 4000",
    "dev:backend": "APP_ROOT=\"$(dirname \"$npm_package_json\")\" && cd \"$APP_ROOT/backend\" && concurrently \"./gradlew bootRun\" \"./gradlew -t compileJava\"",
    "dev": "concurrently 'npm run dev:frontend' 'npm run dev:backend'",
    "dev:backend:plain": "APP_ROOT=\"$(dirname \"$npm_package_json\")\" && cd \"$APP_ROOT/backend\" && ./gradlew bootRun",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "NODE_OPTIONS='--experimental-require-module' vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "questions:backfill-points": "node scripts/backfill-question-points.mjs",
    "ingest:exemplar": "node scripts/ingest-exemplar.mjs",
    "ingest:exemplar:dry": "node scripts/ingest-exemplar.mjs --dry-run",
    "ingest:exemplar:verify": "node scripts/ingest-exemplar.mjs --verify"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/manrope": "^5.2.8",
    "@google/generative-ai": "^0.24.1",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookies-next": "^6.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "kill-port": "^2.0.1",
    "mongodb": "^7.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.1"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "^1.0.0-rc.18"
  }
}
