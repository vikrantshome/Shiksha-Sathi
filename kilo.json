{
  "$schema": "https://kilo.ai/config.json",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "mcp": {
    "crawl4ai": {
      "type": "local",
      "command": ["uv", "run", "--with", "crawl4ai,mcp", "python", "/Users/anuraagpatil/.qwen/mcp-servers/crawl4ai-mcp-wrapper.py"],
      "enabled": true,
      "environment": {},
      "timeout": 120000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true
    },
    "postman": {
      "type": "local",
      "command": ["npx", "@postman/postman-mcp-server@latest"],
      "environment": {
        "POSTMAN_API_KEY": "${input:postman_api_key}"
      },
      "enabled": true
    },
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com",
      "enabled": true
    },
    "atlassian-rovo-mcp-server": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/sse",
      "enabled": true
    },
    "cloudrun": {
      "type": "local",
      "command": ["npx", "-y", "@google-cloud/cloud-run-mcp"],
      "enabled": true
    }
  }
}
